# Release environment variables (copy to your shell or CI secrets)

# Required for EAS cloud build linkage
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Google Play JSON key path for auto submit (global variant)
GOOGLE_PLAY_KEY_PATH=./google-play-key.json

# Optional build profiles
EAS_BUILD_PROFILE=production-global
EAS_SUBMIT_PROFILE=production
