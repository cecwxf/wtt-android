{
  "expo": {
    "name": "WTT",
    "slug": "wtt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wtt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D4ED8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.waxbyte.wtt"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1D4ED8"
      },
      "package": "com.waxbyte.wtt"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WTT to access your photos to share images in chats."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "wttApiUrl": "https://www.waxbyte.com",
      "oauth": {
        "githubClientId": "Ov23lij3HmZln8RdtGvE",
        "googleClientId": "106181430460-5dig1c2j1mglbve1lnjlkmmtmso44g6l.apps.googleusercontent.com",
        "twitterClientId": "TkJ4UThCU3RNX3VFeXEyUEl3MWM6MTpjaQ",
        "redirectUri": "wtt://oauth"
      },
      "eas": {
        "projectId": ""
      }
    }
  }
}
